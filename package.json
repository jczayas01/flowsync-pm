{
  "name": "flowsync-pm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:migrate-all": "psql $DATABASE_URL < prisma/security-additions.sql && psql $DATABASE_URL < prisma/automation-schema.sql && psql $DATABASE_URL < prisma/portfolio-schema.sql && psql $DATABASE_URL < prisma/phase3-schema.sql",
    "setup": "npm install && npm run db:push && npm run db:migrate-all && npm run db:seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.0.0",
    "@kenjiuno/msgreader": "^1.28.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "14.2.18",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^4.13.2",
    "openai": "^4.73.0",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "stripe": "^17.3.1",
    "unpdf": "^1.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
