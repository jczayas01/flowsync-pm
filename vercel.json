{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/ai/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/m365/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/ai/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/ai-report/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/risks-scan/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/import/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/governance/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/export-pdf/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/export-pptx/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/doc-templates/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/free-templates/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/help/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/**/ai-analyze/**/*.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/automation/execute?trigger=SCHEDULE_DAILY",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/automation/execute?trigger=SCHEDULE_WEEKLY",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/trial-reminders",
      "schedule": "30 13 * * *"
    }
  ]
}