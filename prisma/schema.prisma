generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                  @id @default(cuid())
  email                String                  @unique
  emailVerified        DateTime?
  name                 String
  image                String?
  avatarUrl            String?
  timezone             String                  @default("UTC")
  locale               String                  @default("en")
  currency             String                  @default("USD")
  isActive             Boolean                 @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  accounts             Account[]
  passwordResets       PasswordResetToken[]
  auditLogs            AuditLog[]
  approvalRequests     Project[]             @relation("ApprovalRequester")
  baselinesApproved    Baseline[]              @relation("BaselinesApproved")
  baselinesCreated     Baseline[]              @relation("BaselinesCreated")
  benefitsOwned        Benefit[]               @relation("BenefitOwner")
  approvedChanges      ChangeRequest[]         @relation("ChangeApprovedBy")
  requestedChanges     ChangeRequest[]         @relation("ChangeRequestedBy")
  commPlanOwned        CommPlanEntry[]         @relation("CommPlanOwner")
  comments             Comment[]
  decisionsMade        Decision[]              @relation("DecisionMaker")
  documentShares       DocumentShare[]
  uploadedDocuments    Document[]              @relation("UploadedDocuments")
  ownedGoals           Goal[]                  @relation("GoalOwner")
  issuesOwned          Issue[]                 @relation("IssueOwner")
  issuesRaised         Issue[]                 @relation("IssueRaiser")
  lessonsCreated       LessonLearned[]         @relation("LessonsCreated")
  minutesApproved      MeetingMinutes[]        @relation("MinutesApprover")
  minutesCreated       MeetingMinutes[]        @relation("MinutesCreator")
  milestoneAcceptances Milestone[]             @relation("MilestoneAcceptances")
  notifications        Notification[]          @relation("UserNotifications")
  ownedPortfolios      Portfolio[]
  procurementCreated   ProcurementItem[]       @relation("ProcurementCreator")
  procurementOwned     ProcurementItem[]       @relation("ProcurementOwner")
  managedPrograms      Program[]
  projectsClosed       ProjectClosure[]        @relation("ProjectCloser")
  intakeReviewed       ProjectIntake[]         @relation("IntakeReviewed")
  intakeSubmitted      ProjectIntake[]         @relation("IntakeSubmitted")
  projectMember        ProjectMember[]
  createdProjects      Project[]               @relation("ProjectCreator")
  qcCreated            QualityChecklist[]      @relation("QCCreator")
  qcReviewed           QualityChecklist[]      @relation("QCReviewer")
  qmpApproved          QualityManagementPlan[] @relation("QMPApprover")
  qmpCreated           QualityManagementPlan[] @relation("QMPCreator")
  reportTemplates      ReportTemplate[]        @relation("ReportTemplateCreator")
  requirementsCreated  Requirement[]           @relation("RequirementCreator")
  requirementsOwned    Requirement[]           @relation("RequirementOwner")
  ownedRisks           Risk[]
  sessions             Session[]
  statusUpdates        StatusUpdate[]
  tasksAssigned        TaskAssignee[]
  tasksOwned           Task[]                  @relation("TaskOwner")
  teamChartersCreated  TeamCharter[]           @relation("TeamCharterCreator")
  timeEntries          TimeEntry[]
  transitionCreated    TransitionPlan[]        @relation("TransitionCreator")
  wbsEntriesCreated    WbsEntry[]              @relation("WbsEntryCreator")
  memberships          WorkspaceMember[]

  commentReads    CommentRead[]

  @@map("users")
}

model DemoRequest {
  id          String    @id @default(cuid())
  name        String
  email       String
  company     String
  teamSize    String?
  phone       String?
  message     String?
  locale      String    @default("en")
  source      String    @default("landing")   // landing | pricing | app
  status      String    @default("NEW")       // NEW | CONTACTED | QUALIFIED | WON | LOST
  notes       String?
  contactedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("demo_requests")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique          // sha256 of the emailed token — raw token is never stored
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  // NextAuth adapter contract — provider MUST be String ("microsoft-entra-id", "google", …)
  // Legacy app values ("EMAIL", "AZURE_AD", "MICROSOFT") remain valid as plain strings.
  type              String?
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  // App-specific (pre-existing): EMAIL password hash lives in accessToken; M365 tokens.
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?
  tenantId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Workspace {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  plan                 Plan                  @default(FREE)
  logoUrl              String?
  primaryColor         String                @default("#1B6CA8")
  accentColor          String                @default("#F59E0B")
  stripeCustomerId     String?               @unique
  stripeSubscriptionId String?               @unique
  trialEndsAt          DateTime?
  planRenewsAt         DateTime?
  seats                Int                   @default(1)
  azureTenantId        String?
  azureClientId        String?
  ssoEnabled           Boolean               @default(false)
  defaultTimezone      String                @default("UTC")
  defaultCurrency      String                @default("USD")
  weekStartsOn         Int                   @default(1)
  fiscalYearStartMonth Int                   @default(1)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  automationLogs       AutomationLog[]
  automationRules      AutomationRule[]
  goals                Goal[]
  portfolios           Portfolio[]
  intakes              ProjectIntake[]
  projects             Project[]
  reportTemplates      ReportTemplate[]
  templates            Template[]
  webhooks             Webhook[]
  invitations          WorkspaceInvitation[]
  members              WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole  @default(MEMBER)
  joinedAt    DateTime  @default(now())
  invitedBy   String?
  skills      String[]  @default([])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        UserRole  @default(MEMBER)
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedBy   String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_invitations")
}

model Project {
  id                String                 @id @default(cuid())
  workspaceId       String
  createdById       String
  code              String
  name              String
  description       String?
  methodology       Methodology
  status            ProjectStatus          @default(DRAFT)
  approvalRequestedAt   DateTime?
  approvalRequestedById String?
  approvalRequestedBy   User?                @relation("ApprovalRequester", fields: [approvalRequestedById], references: [id])
  health            ProjectHealth          @default(GREEN)
  startDate         DateTime?
  endDate           DateTime?
  actualEnd         DateTime?
  budgetTotal       Decimal                @default(0) @db.Decimal(15, 2)
  budgetSpent       Decimal                @default(0) @db.Decimal(15, 2)
  settings          Json?
  currency          String                 @default("USD")
  percentComplete   Int                    @default(0)
  timezone          String                 @default("UTC")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  programId         String?
  objective         String?
  scope             String?
  assumptions       String?
  background        String?
  constraints       String?
  economicImpact    String?
  isConfidential    Boolean                @default(false)
  outOfScope        String?
  priority          TaskPriority           @default(MEDIUM)
  baselines         Baseline[]
  benefits          Benefit[]
  budget            BudgetItem[]
  changes           ChangeRequest[]
  commPlan          CommPlanEntry[]
  customFields      CustomFieldValue[]
  decisions         Decision[]
  documents         Document[]
  goalLinks         GoalProject[]
  issues            Issue[]
  lessons           LessonLearned[]
  meetingMinutes    MeetingMinutes[]
  milestones        Milestone[]
  phases            Phase[]
  procurement       ProcurementItem[]
  closure           ProjectClosure?
  members           ProjectMember[]
  tags              ProjectTag[]
  createdBy         User                   @relation("ProjectCreator", fields: [createdById], references: [id])
  program           Program?               @relation(fields: [programId], references: [id])
  workspace         Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  qualityChecklists QualityChecklist[]
  qualityPlan       QualityManagementPlan?
  reports           Report[]
  requirements      Requirement[]
  risks             Risk[]
  sprints           Sprint[]
  statusUpdates     StatusUpdate[]
  tasks             Task[]
  teamCharter       TeamCharter?
  timeEntries       TimeEntry[]
  transitionPlan    TransitionPlan?
  wbsEntries        WbsEntry[]

  @@unique([workspaceId, code])
  @@map("projects")
}

model ProjectMember {
  id            String         @id @default(cuid())
  projectId     String
  userId        String
  role          UserRole       @default(MEMBER)
  allocation    Int            @default(100)
  joinedAt      DateTime       @default(now())
  projectRole   ProjectRole?
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskAssignees TaskAssignee[]

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  name      String
  color     String  @default("#1B6CA8")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("project_tags")
}

model Phase {
  id             String      @id @default(cuid())
  projectId      String
  name           String
  description    String?
  order          Int
  status         PhaseStatus @default(PENDING)
  plannedStart   DateTime?
  plannedEnd     DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  gateApproved   Boolean     @default(false)
  gateApprovedBy String?
  gateApprovedAt DateTime?
  gateNotes      String?
  color          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@map("phases")
}

model Task {
  id              String           @id @default(cuid())
  projectId       String
  phaseId         String?
  sprintId        String?
  parentId        String?
  code            String
  title           String
  description     String?
  status          TaskStatus       @default(TODO)
  priority        TaskPriority     @default(MEDIUM)
  startDate       DateTime?
  dueDate         DateTime?
  completedAt     DateTime?
  estimatedHours  Decimal?         @db.Decimal(8, 2)
  actualHours     Decimal?         @db.Decimal(8, 2)
  remainingHours  Decimal?         @db.Decimal(8, 2)
  storyPoints     Int?
  percentComplete Int              @default(0)
  isCriticalPath  Boolean          @default(false)
  ownerId         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sortOrder       Int              @default(0)
  isMilestone     Boolean          @default(false)
  attachments     Attachment[]
  comments        Comment[]
  commentReads    CommentRead[]
  assignees       TaskAssignee[]
  dependencies    TaskDependency[] @relation("DependentTask")
  dependents      TaskDependency[] @relation("PrecedingTask")
  owner           User?            @relation("TaskOwner", fields: [ownerId], references: [id])
  parent          Task?            @relation("SubTasks", fields: [parentId], references: [id])
  subtasks        Task[]           @relation("SubTasks")
  phase           Phase?           @relation(fields: [phaseId], references: [id])
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint          Sprint?          @relation(fields: [sprintId], references: [id])
  timeEntries     TimeEntry[]

  @@unique([projectId, code])
  @@map("tasks")
}

model TaskAssignee {
  id              String        @id @default(cuid())
  taskId          String
  userId          String
  projectMemberId String
  assignedAt      DateTime      @default(now())
  projectMember   ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  task            Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, projectMemberId])
  @@map("task_assignees")
}

model TaskDependency {
  id              String   @id @default(cuid())
  dependentTaskId String
  precedingTaskId String
  dependencyType  String   @default("FS")
  lagDays         Int      @default(0)
  createdAt       DateTime @default(now())
  dependentTask   Task     @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  precedingTask   Task     @relation("PrecedingTask", fields: [precedingTaskId], references: [id], onDelete: Cascade)

  @@unique([dependentTaskId, precedingTaskId])
  @@map("task_dependencies")
}

model Milestone {
  id              String          @id @default(cuid())
  projectId       String
  name            String
  description     String?
  dueDate         DateTime
  achievedAt      DateTime?
  status          MilestoneStatus @default(UPCOMING)
  color           String          @default("#F59E0B")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  acceptanceNotes String?
  acceptedAt      DateTime?
  acceptedById    String?
  acceptedBy      User?           @relation("MilestoneAcceptances", fields: [acceptedById], references: [id])
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model LessonLearned {
  id             String         @id @default(cuid())
  projectId      String
  title          String
  category       LessonCategory @default(OTHER)
  phase          String?
  situation      String
  lesson         String
  recommendation String
  impact         String?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdBy      User           @relation("LessonsCreated", fields: [createdById], references: [id])
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("lessons_learned")
}

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  code        String
  title       String
  description String?
  category    String?
  priority    IssuePriority @default(MEDIUM)
  status      IssueStatus   @default(OPEN)
  impact      String?
  resolution  String?
  ownerId     String?
  dueDate     DateTime?
  resolvedAt  DateTime?
  raisedById  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User?         @relation("IssueOwner", fields: [ownerId], references: [id])
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedBy    User          @relation("IssueRaiser", fields: [raisedById], references: [id])

  @@unique([projectId, code])
  @@map("issues")
}

model Decision {
  id           String   @id @default(cuid())
  projectId    String
  code         String
  title        String
  description  String?
  rationale    String?
  alternatives String?
  impact       String?
  madeById     String
  madeAt       DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  madeBy       User     @relation("DecisionMaker", fields: [madeById], references: [id])
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@map("decisions")
}

model Benefit {
  id             String        @id @default(cuid())
  projectId      String
  title          String
  description    String?
  category       String?
  status         BenefitStatus @default(PROJECTED)
  projectedValue String?
  actualValue    String?
  measureBy      DateTime?
  measuredAt     DateTime?
  ownerId        String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  owner          User?         @relation("BenefitOwner", fields: [ownerId], references: [id])
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("benefits")
}

model CommPlanEntry {
  id                String   @id @default(cuid())
  projectId         String
  stakeholderName   String
  role              String?
  information       String
  format            String?
  frequency         String?
  method            String?
  ownerId           String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  engagementCurrent String?  @default("NEUTRAL")
  engagementTarget  String?  @default("SUPPORTIVE")
  influence         String?
  interest          String?
  owner             User?    @relation("CommPlanOwner", fields: [ownerId], references: [id])
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("comm_plan_entries")
}

model TeamCharter {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  vision             String?
  objectives         String?
  values             String?
  norms              String?
  decisionMaking     String?
  conflictResolution String?
  communicationPlan  String?
  toolsAndProcesses  String?
  signatures         String?
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          User     @relation("TeamCharterCreator", fields: [createdById], references: [id])
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("team_charters")
}

model WbsEntry {
  id                 String   @id @default(cuid())
  projectId          String
  taskId             String?
  code               String
  title              String
  description        String?
  acceptanceCriteria String?
  assumptions        String?
  responsible        String?
  estimatedHours     Decimal? @db.Decimal(10, 2)
  estimatedCost      Decimal? @db.Decimal(15, 2)
  qualityStandards   String?
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          User     @relation("WbsEntryCreator", fields: [createdById], references: [id])
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("wbs_entries")
}

model QualityManagementPlan {
  id                String    @id @default(cuid())
  projectId         String    @unique
  qualityStandards  String?
  qualityObjectives String?
  roles             String?
  processes         String?
  tools             String?
  metrics           String?
  audits            String?
  nonConformance    String?
  status            String    @default("DRAFT")
  approvedById      String?
  approvedAt        DateTime?
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  approvedBy        User?     @relation("QMPApprover", fields: [approvedById], references: [id])
  createdBy         User      @relation("QMPCreator", fields: [createdById], references: [id])
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("quality_management_plans")
}

model QualityChecklist {
  id           String    @id @default(cuid())
  projectId    String
  deliverable  String
  phaseId      String?
  items        Json
  status       String    @default("PENDING")
  reviewedById String?
  reviewedAt   DateTime?
  notes        String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    User      @relation("QCCreator", fields: [createdById], references: [id])
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewedBy   User?     @relation("QCReviewer", fields: [reviewedById], references: [id])

  @@map("quality_checklists")
}

model Requirement {
  id                 String   @id @default(cuid())
  projectId          String
  code               String
  title              String
  description        String?
  type               String   @default("FUNCTIONAL")
  priority           String   @default("MEDIUM")
  status             String   @default("DRAFT")
  source             String?
  acceptanceCriteria String?
  traceability       String?
  ownerId            String?
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          User     @relation("RequirementCreator", fields: [createdById], references: [id])
  owner              User?    @relation("RequirementOwner", fields: [ownerId], references: [id])
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("requirements")
}

model MeetingMinutes {
  id           String    @id @default(cuid())
  projectId    String
  code         String
  title        String
  meetingType  String    @default("STATUS")   // KICKOFF|STATUS|PHASE_GATE|RISK_REVIEW|STEERING|SPRINT_PLANNING|RETROSPECTIVE|AD_HOC|OTHER
  meetingDate  DateTime
  location     String?
  facilitator  String?
  attendees    Json
  agenda       String?
  discussion   String?
  decisions    Json      @default("[]")
  actionItems  Json      @default("[]")
  nextMeeting  DateTime?
  nextAgenda   String?
  status       String    @default("DRAFT")
  approvedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  approvedBy   User?     @relation("MinutesApprover", fields: [approvedById], references: [id])
  createdBy    User      @relation("MinutesCreator", fields: [createdById], references: [id])
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("meeting_minutes")
}

model TransitionPlan {
  id                 String    @id @default(cuid())
  projectId          String    @unique
  // Field names match the UI form, the /handover route and the AI ingest prompt.
  // @map keeps the original DB columns, so only the two genuinely new ones migrate.
  overview            String?
  operationsContact   String?   @map("operationsOwner")
  systemsHandedOver   String?
  handoverDate        DateTime?
  trainingCompleted   String?   @map("trainingPlan")
  documentation       String?
  supportArrangements String?   @map("supportArrangement")
  knownIssues         String?   @map("risksPostHandover")
  knowledgeTransfer   String?
  successCriteria     String?
  signoffs           Json      @default("[]")
  status             String    @default("DRAFT")
  createdById        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          User      @relation("TransitionCreator", fields: [createdById], references: [id])
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("transition_plans")
}

model ProcurementItem {
  id            String    @id @default(cuid())
  projectId     String
  vendorName    String
  vendorContact String?
  vendorEmail   String?
  vendorPhone   String?
  vendorLocation String?
  type          String
  title         String
  poNumber      String?
  contractRef   String?
  value         Decimal?  @db.Decimal(15, 2)
  currency      String    @default("USD")
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("ACTIVE")
  deliverables  String?
  notes         String?
  attachmentUrl String?
  ownerId       String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     User      @relation("ProcurementCreator", fields: [createdById], references: [id])
  owner         User?     @relation("ProcurementOwner", fields: [ownerId], references: [id])
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("procurement_items")
}

model ProjectClosure {
  id                    String    @id @default(cuid())
  projectId             String    @unique
  deliverablesAccepted  Boolean   @default(false)
  acceptanceDocSigned   Boolean   @default(false)
  knowledgeTransferred  Boolean   @default(false)
  documentationComplete Boolean   @default(false)
  finalBudgetReported   Boolean   @default(false)
  contractsClosed       Boolean   @default(false)
  teamReleased          Boolean   @default(false)
  performanceReviewed   Boolean   @default(false)
  lessonsDocumented     Boolean   @default(false)
  lessonsShared         Boolean   @default(false)
  benefitsHandedOver    Boolean   @default(false)
  finalReportComplete   Boolean   @default(false)
  closureDate           DateTime?
  closureNotes          String?
  closedById            String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
