// Proaxis PM — Prisma Schema v1.0
// Database: PostgreSQL (Supabase)
// Phase 1 — Foundation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN   // Proaxis PM platform admin
  OWNER         // Workspace owner (created it)
  ADMIN         // Workspace admin
  PM            // Project Manager
  MEMBER        // Regular team member
  VIEWER        // Read-only access
  CLIENT        // External client (limited view)
}

enum Plan {
  FREE
  PRO
  CONSULTANT
  BUSINESS
  ENTERPRISE
}

enum AuthProvider {
  EMAIL
  GOOGLE
  MICROSOFT
  AZURE_AD
}

enum Methodology {
  WATERFALL
  AGILE
  SCRUM
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectHealth {
  GREEN   // On track
  AMBER   // At risk
  RED     // Off track
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  SKIPPED
}

enum MilestoneStatus {
  UPCOMING
  ACHIEVED
  MISSED
  AT_RISK
}

enum RiskProbability {
  VERY_LOW    // 1-20%
  LOW         // 21-40%
  MEDIUM      // 41-60%
  HIGH        // 61-80%
  VERY_HIGH   // 81-100%
}

enum RiskImpact {
  NEGLIGIBLE
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
  TRIGGERED
}

enum ChangeStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum BudgetCategory {
  LABOR
  MATERIALS
  EQUIPMENT
  TRAVEL
  SOFTWARE
  CONSULTING
  CONTINGENCY
  OTHER
}

enum ReportType {
  WEEKLY_STATUS
  EXECUTIVE_SUMMARY
  RISK_REPORT
  BUDGET_REPORT
  MILESTONE_REPORT
}

enum SprintStatus {
  PLANNING
  ACTIVE
  REVIEW
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  MILESTONE_DUE
  RISK_ESCALATED
  CHANGE_APPROVED
  PROJECT_STATUS
  BUDGET_ALERT
  MENTION
  REPORT_READY
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatarUrl     String?
  timezone      String    @default("UTC")
  locale        String    @default("en")
  currency      String    @default("USD")
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   WorkspaceMember[]
  projectMember ProjectMember[]
  tasksOwned    Task[]          @relation("TaskOwner")
  tasksAssigned TaskAssignee[]
  comments      Comment[]
  notifications Notification[]
  auditLogs     AuditLog[]
  timeEntries   TimeEntry[]
  createdProjects Project[]     @relation("ProjectCreator")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  accessToken       String?  @db.Text
  refreshToken      String?  @db.Text
  tokenExpiresAt    DateTime?
  scope             String?
  // Azure AD specific
  tenantId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// WORKSPACE (Multi-tenancy core)
// ─────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique  // used in URLs: proaxispm.com/ws/acme-corp
  plan        Plan     @default(FREE)
  
  // Branding (white-label Phase 1)
  logoUrl     String?
  primaryColor String  @default("#1B6CA8")
  accentColor  String  @default("#F59E0B")
  
  // Billing
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  trialEndsAt          DateTime?
  planRenewsAt         DateTime?
  seats                Int      @default(1)
  
  // Azure AD (Business/Enterprise)
  azureTenantId   String?
  azureClientId   String?
  ssoEnabled      Boolean  @default(false)
  
  // Settings
  defaultTimezone     String  @default("UTC")
  defaultCurrency     String  @default("USD")
  weekStartsOn        Int     @default(1) // 1=Monday
  fiscalYearStartMonth Int    @default(1)
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  projects    Project[]
  templates   Template[]
  auditLogs   AuditLog[]
  invitations WorkspaceInvitation[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole  @default(MEMBER)
  joinedAt    DateTime  @default(now())
  invitedBy   String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        UserRole  @default(MEMBER)
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedBy   String
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_invitations")
}

// ─────────────────────────────────────────────
// PROJECT (Core entity)
// ─────────────────────────────────────────────

model Project {
  id           String      @id @default(cuid())
  workspaceId  String
  createdById  String
  
  // Identity
  code         String      // e.g. "PRJ-001" — auto-generated per workspace
  name         String
  description  String?     @db.Text
  methodology  Methodology
  status       ProjectStatus @default(DRAFT)
  health       ProjectHealth @default(GREEN)
  
  // Dates
  startDate    DateTime?
  endDate      DateTime?
  actualEnd    DateTime?
  
  // Budget summary (detail in BudgetItem)
  budgetTotal  Decimal     @default(0) @db.Decimal(15,2)
  budgetSpent  Decimal     @default(0) @db.Decimal(15,2)
  currency     String      @default("USD")
  
  // Progress
  percentComplete Int      @default(0)
  
  // Settings
  timezone     String      @default("UTC")
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User        @relation("ProjectCreator", fields: [createdById], references: [id])
  members      ProjectMember[]
  phases       Phase[]
  tasks        Task[]
  milestones   Milestone[]
  risks        Risk[]
  changes      ChangeRequest[]
  budget       BudgetItem[]
  baselines    Baseline[]
  reports      Report[]
  sprints      Sprint[]
  documents    Document[]
  timeEntries  TimeEntry[]
  tags         ProjectTag[]
  customFields CustomFieldValue[]
  statusUpdates StatusUpdate[]

  @@unique([workspaceId, code])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      UserRole @default(MEMBER)
  // Resource planning
  allocation Int     @default(100) // percentage 0-100
  joinedAt  DateTime @default(now())
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskAssignees TaskAssignee[]

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  name      String
  color     String  @default("#1B6CA8")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("project_tags")
}

// ─────────────────────────────────────────────
// PHASES (Waterfall gate-driven)
// ─────────────────────────────────────────────

model Phase {
  id           String      @id @default(cuid())
  projectId    String
  name         String
  description  String?
  order        Int
  status       PhaseStatus @default(PENDING)
  
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  
  // Gate approval
  gateApproved    Boolean   @default(false)
  gateApprovedBy  String?
  gateApprovedAt  DateTime?
  gateNotes       String?   @db.Text
  
  color        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("phases")
}

// ─────────────────────────────────────────────
// TASKS (Universal — all methodologies)
// ─────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  projectId   String
  phaseId     String?
  sprintId    String?
  parentId    String?      // subtasks
  
  code        String       // e.g. "T-001"
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  
  // Dates
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  
  // Estimates
  estimatedHours  Decimal? @db.Decimal(8,2)
  actualHours     Decimal? @db.Decimal(8,2)
  remainingHours  Decimal? @db.Decimal(8,2)
  
  // Agile / Scrum
  storyPoints Int?
  
  // Gantt
  percentComplete Int      @default(0)
  isCriticalPath  Boolean  @default(false)
  
  ownerId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase        Phase?        @relation(fields: [phaseId], references: [id])
  sprint       Sprint?       @relation(fields: [sprintId], references: [id])
  parent       Task?         @relation("SubTasks", fields: [parentId], references: [id])
  subtasks     Task[]        @relation("SubTasks")
  owner        User?         @relation("TaskOwner", fields: [ownerId], references: [id])
  assignees    TaskAssignee[]
  dependencies TaskDependency[] @relation("DependentTask")
  dependents   TaskDependency[] @relation("PrecedingTask")
  comments     Comment[]
  timeEntries  TimeEntry[]
  attachments  Attachment[]

  @@unique([projectId, code])
  @@map("tasks")
}

model TaskAssignee {
  id              String  @id @default(cuid())
  taskId          String
  projectMemberId String
  assignedAt      DateTime @default(now())

  task          Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([taskId, projectMemberId])
  @@map("task_assignees")
}

model TaskDependency {
  id              String @id @default(cuid())
  dependentTaskId String  // task that depends on another
  precedingTaskId String  // task that must come first
  // FS = Finish-to-Start (default), SS, FF, SF
  dependencyType  String @default("FS")
  lagDays         Int    @default(0)
  createdAt       DateTime @default(now())

  dependentTask Task @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  precedingTask Task @relation("PrecedingTask", fields: [precedingTaskId], references: [id], onDelete: Cascade)

  @@unique([dependentTaskId, precedingTaskId])
  @@map("task_dependencies")
}

// ─────────────────────────────────────────────
// MILESTONES
// ─────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime
  achievedAt  DateTime?
  status      MilestoneStatus @default(UPCOMING)
  color       String          @default("#F59E0B")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// ─────────────────────────────────────────────
// BASELINE (Snapshot of plan at a point in time)
// ─────────────────────────────────────────────

model Baseline {
  id          String   @id @default(cuid())
  projectId   String
  name        String   // e.g. "Baseline 1 — Approved 2026-03-01"
  description String?
  
  // Frozen copies of key metrics at baseline creation
  snapshotData Json    // { tasks: [...], budget: {...}, schedule: {...} }
  
  budgetTotal Decimal  @db.Decimal(15,2)
  startDate   DateTime
  endDate     DateTime
  
  createdById String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("baselines")
}

// ─────────────────────────────────────────────
// RISK MANAGEMENT
// ─────────────────────────────────────────────

model Risk {
  id           String          @id @default(cuid())
  projectId    String
  code         String          // e.g. "RSK-001"
  title        String
  description  String?         @db.Text
  category     String?         // Schedule, Budget, Technical, Resource, etc.
  
  probability  RiskProbability
  impact       RiskImpact
  // score = probability * impact (calculated)
  score        Int             // 1-25
  
  status       RiskStatus      @default(OPEN)
  ownerId      String?
  
  // Response
  mitigationPlan String?       @db.Text
  contingencyPlan String?      @db.Text
  
  identifiedAt DateTime        @default(now())
  reviewDate   DateTime?
  closedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@unique([projectId, code])
  @@map("risks")
}

// ─────────────────────────────────────────────
// CHANGE CONTROL
// ─────────────────────────────────────────────

model ChangeRequest {
  id          String       @id @default(cuid())
  projectId   String
  code        String       // e.g. "CR-001"
  title       String
  description String?      @db.Text
  
  // Impact assessment
  scheduleImpact  String?  // e.g. "+5 days"
  budgetImpact    Decimal? @db.Decimal(15,2)
  scopeImpact     String?  @db.Text
  qualityImpact   String?  @db.Text
  
  status      ChangeStatus @default(DRAFT)
  priority    TaskPriority @default(MEDIUM)
  
  requestedById  String
  approvedById   String?
  approvedAt     DateTime?
  implementedAt  DateTime?
  rejectedReason String?   @db.Text
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@unique([projectId, code])
  @@map("change_requests")
}

// ─────────────────────────────────────────────
// BUDGET MANAGEMENT
// ─────────────────────────────────────────────

model BudgetItem {
  id          String         @id @default(cuid())
  projectId   String
  category    BudgetCategory
  name        String
  description String?
  
  // Planned vs Actual (Earned Value)
  plannedCost  Decimal       @db.Decimal(15,2)
  actualCost   Decimal       @default(0) @db.Decimal(15,2)
  earnedValue  Decimal       @default(0) @db.Decimal(15,2)
  
  currency     String        @default("USD")
  
  // Period
  periodStart  DateTime?
  periodEnd    DateTime?
  
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@map("budget_items")
}

model Expense {
  id           String   @id @default(cuid())
  budgetItemId String
  description  String
  amount       Decimal  @db.Decimal(15,2)
  currency     String   @default("USD")
  date         DateTime
  receiptUrl   String?
  approvedById String?
  createdById  String
  createdAt    DateTime @default(now())

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ─────────────────────────────────────────────
// SCRUM / AGILE — Sprints
// ─────────────────────────────────────────────

model Sprint {
  id          String       @id @default(cuid())
  projectId   String
  name        String       // e.g. "Sprint 1"
  goal        String?      @db.Text
  status      SprintStatus @default(PLANNING)
  
  startDate   DateTime
  endDate     DateTime
  
  // Velocity
  plannedPoints  Int?
  completedPoints Int?
  
  retroNotes  String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("sprints")
}

// ─────────────────────────────────────────────
// STATUS REPORTS
// ─────────────────────────────────────────────

model StatusUpdate {
  id             String      @id @default(cuid())
  projectId      String
  type           ReportType  @default(WEEKLY_STATUS)
  
  // Period
  periodStart    DateTime
  periodEnd      DateTime
  
  health         ProjectHealth
  
  // Report sections
  summary        String?     @db.Text
  accomplishments String?    @db.Text
  nextSteps      String?     @db.Text
  risks          String?     @db.Text
  issues         String?     @db.Text
  
  // Budget snapshot at report time
  budgetPlanned  Decimal?    @db.Decimal(15,2)
  budgetActual   Decimal?    @db.Decimal(15,2)
  
  // Schedule snapshot
  percentComplete Int?
  scheduledEnd   DateTime?
  forecastEnd    DateTime?
  
  // AI generated?
  aiGenerated    Boolean     @default(false)
  aiPrompt       String?     @db.Text
  
  createdById    String
  publishedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("status_updates")
}

// ─────────────────────────────────────────────
// REPORTS (Generated documents)
// ─────────────────────────────────────────────

model Report {
  id          String     @id @default(cuid())
  projectId   String
  type        ReportType
  name        String
  fileUrl     String?    // stored in Supabase Storage
  fileType    String?    // pdf, docx, pptx
  aiGenerated Boolean    @default(false)
  createdById String
  createdAt   DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("reports")
}

// ─────────────────────────────────────────────
// DOCUMENTS & ATTACHMENTS
// ─────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  fileUrl     String
  fileType    String
  fileSize    Int?     // bytes
  version     Int      @default(1)
  uploadedById String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Attachment {
  id        String   @id @default(cuid())
  taskId    String
  name      String
  fileUrl   String
  fileType  String
  fileSize  Int?
  uploadedById String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─────────────────────────────────────────────
// COMMENTS
// ─────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  
  // Polymorphic — comment can be on task, risk, or change request
  taskId          String?
  riskId          String?
  changeRequestId String?
  
  // AI generated?
  aiGenerated Boolean @default(false)
  
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author        User           @relation(fields: [authorId], references: [id])
  task          Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  risk          Risk?          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  changeRequest ChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ─────────────────────────────────────────────
// TIME TRACKING
// ─────────────────────────────────────────────

model TimeEntry {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  userId      String
  
  description String?
  hours       Decimal  @db.Decimal(6,2)
  date        DateTime
  
  // Billing
  billable    Boolean  @default(true)
  hourlyRate  Decimal? @db.Decimal(10,2)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

// ─────────────────────────────────────────────
// TEMPLATES (schema ready, marketplace Phase 2)
// ─────────────────────────────────────────────

model Template {
  id           String      @id @default(cuid())
  workspaceId  String?     // null = system template (built-in)
  name         String
  description  String?
  methodology  Methodology
  industry     String?     // Healthcare, Construction, IT, etc.
  
  // Frozen project structure
  templateData Json        // phases, tasks, milestones, risk categories
  
  isPublic     Boolean     @default(false) // Phase 2: marketplace
  isPremium    Boolean     @default(false) // Phase 2: paid templates
  price        Decimal?    @db.Decimal(10,2)
  
  usageCount   Int         @default(0)
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@map("templates")
}

// ─────────────────────────────────────────────
// CUSTOM FIELDS (flex schema)
// ─────────────────────────────────────────────

model CustomField {
  id          String  @id @default(cuid())
  workspaceId String
  entityType  String  // "project" | "task" | "risk"
  name        String
  fieldType   String  // "text" | "number" | "date" | "select" | "boolean"
  options     Json?   // for select fields
  required    Boolean @default(false)
  order       Int     @default(0)
  createdAt   DateTime @default(now())

  values CustomFieldValue[]

  @@map("custom_fields")
}

model CustomFieldValue {
  id            String  @id @default(cuid())
  customFieldId String
  projectId     String?
  entityId      String  // ID of project/task/risk
  value         String? @db.Text
  updatedAt     DateTime @updatedAt

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id])

  @@unique([customFieldId, entityId])
  @@map("custom_field_values")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  entityType String?          // "task" | "risk" | "project" etc.
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  
  action      String   // "project.created", "task.status_changed", etc.
  entityType  String
  entityId    String
  
  before      Json?    // previous state
  after       Json?    // new state
  
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
