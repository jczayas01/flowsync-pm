# ══════════════════════════════════════════════════════════
# FloesyncPM — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to git. It is in .gitignore.
#
# Where to find each value is documented inline.
# Required = app will not start without it
# Optional = feature will be disabled if missing
# ══════════════════════════════════════════════════════════


# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────

# Your public domain (no trailing slash)
# Local:      http://localhost:3000
# Production: https://floesyncpm.com
NEXT_PUBLIC_APP_URL="https://floesyncpm.com"

# App name shown in emails and UI
NEXT_PUBLIC_APP_NAME="FloesyncPM"


# ──────────────────────────────────────────────
# DATABASE  [Required]
# Supabase → Project → Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543)
# Use "Session" mode URL for DIRECT_URL (port 5432)
# ──────────────────────────────────────────────

DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"


# ──────────────────────────────────────────────
# NEXTAUTH  [Required]
# NEXTAUTH_SECRET: run `openssl rand -base64 32` in terminal
# ──────────────────────────────────────────────

NEXTAUTH_URL="https://floesyncpm.com"
NEXTAUTH_SECRET=""


# ──────────────────────────────────────────────
# GOOGLE OAUTH  [Optional — enables "Sign in with Google"]
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://floesyncpm.com/api/auth/callback/google
# ──────────────────────────────────────────────

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ──────────────────────────────────────────────
# MICROSOFT OAUTH  [Optional — enables "Sign in with Microsoft"]
# Azure Portal → App registrations → New registration
# Redirect URI: https://floesyncpm.com/api/auth/callback/azure-ad
# ──────────────────────────────────────────────

MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"


# ──────────────────────────────────────────────
# AZURE AD SSO  [Optional — Business/Enterprise plan SSO]
# Same Azure App Registration as Microsoft OAuth above
# or a separate enterprise app for SAML/OIDC SSO
# ──────────────────────────────────────────────

AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"


# ──────────────────────────────────────────────
# MICROSOFT GRAPH API  [Optional — enables M365 integration]
# Azure Portal → App registrations → [your app] → API permissions
# Required permissions: Mail.Read, Calendars.Read, Tasks.ReadWrite
# Grant admin consent for your tenant
# ──────────────────────────────────────────────

GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
GRAPH_TENANT_ID=""


# ──────────────────────────────────────────────
# AZURE OPENAI  [Optional — enables AI co-pilot & reports]
# Azure Portal → Azure OpenAI → [resource] → Keys and Endpoint
# Deploy GPT-4o model in Azure OpenAI Studio first
# ──────────────────────────────────────────────

AZURE_OPENAI_ENDPOINT="https://[your-resource].openai.azure.com"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT_GPT4O="gpt-4o"
AZURE_OPENAI_DEPLOYMENT_MINI="gpt-4o-mini"
AZURE_OPENAI_API_VERSION="2024-02-01"


# ──────────────────────────────────────────────
# STRIPE  [Optional — enables paid plans & billing]
# dashboard.stripe.com → Developers → API keys
# Webhook: dashboard.stripe.com → Webhooks → Add endpoint
#   URL: https://floesyncpm.com/api/stripe/webhook
#   Events: checkout.session.completed, customer.subscription.*,
#           invoice.payment_succeeded, invoice.payment_failed
# ──────────────────────────────────────────────

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs — create in Stripe dashboard → Products
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_ANNUAL=""
STRIPE_PRICE_CONSULTANT_MONTHLY=""
STRIPE_PRICE_CONSULTANT_ANNUAL=""


# ──────────────────────────────────────────────
# RESEND  [Optional — enables transactional email]
# resend.com → API Keys → Create API Key
# Also verify your sending domain: resend.com → Domains
# ──────────────────────────────────────────────

RESEND_API_KEY=""
RESEND_FROM_EMAIL="FloesyncPM <no-reply@floesyncpm.com>"
RESEND_REPLY_TO="support@floesyncpm.com"


# ──────────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────────

# Used to encrypt 2FA secrets and session tokens
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# Used to sign webhook payloads
# Generate: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=""


# ──────────────────────────────────────────────
# FEATURE FLAGS  [Optional]
# Set to "true" to enable, leave empty to disable
# ──────────────────────────────────────────────

# Show "Early access" banner and waitlist on landing page
NEXT_PUBLIC_SHOW_WAITLIST="true"

# Enable AI features (requires Azure OpenAI above)
NEXT_PUBLIC_AI_ENABLED="true"

# Enable M365 integration tab in settings
NEXT_PUBLIC_M365_ENABLED="true"

# Maintenance mode — shows maintenance page to all visitors
NEXT_PUBLIC_MAINTENANCE_MODE=""

# Supabase Storage — for project document file uploads
# Supabase → Project → Settings → API → Project URL + service_role key
SUPABASE_URL="https://zsfqzxzekladzxjzuiog.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL="https://zsfqzxzekladzxjzuiog.supabase.co"

# AI Features — uses Anthropic API (same as Claude)
# Anthropic Console → API Keys
ANTHROPIC_API_KEY=""
